# Copy to .env.local and fill in from Supabase Dashboard → Project Settings → API Keys.
# Both values are server-only secrets — never add a NEXT_PUBLIC_ prefix and never commit .env.local.

# Project URL, e.g. https://<project-ref>.supabase.co
SUPABASE_URL=

# Secret key (sb_secret_...). Bypasses RLS — server-side use only.
# Legacy projects: the service_role JWT works here too.
SUPABASE_SECRET_KEY=
